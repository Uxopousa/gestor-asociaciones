<section class="mb-8 pt-2 lg:mb-10">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-2">
            <% if (eyebrow) { %>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-zinc-500"><%= eyebrow %></p>
            <% } %>

            <h2 class="text-[28px] font-semibold tracking-tight text-zinc-950 sm:text-[32px]"><%= title %></h2>

            <% if (description) { %>
                <p class="max-w-3xl text-sm leading-6 text-zinc-500 sm:text-[15px] sm:leading-6"><%= description %></p>
            <% } %>
        </div>

        <% if (action) { %>
            <div class="flex flex-wrap items-center gap-3">
                <%- action %>
            </div>
        <% } %>
    </div>
</section>