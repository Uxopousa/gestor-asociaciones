<header class="border-b border-zinc-200 bg-white">
    <div class="mx-auto flex min-h-20 w-full max-w-[1440px] items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8 lg:py-5">
        <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.26em] text-zinc-500">Gestor de Asociaciones</p>
            <h1 class="mt-1 text-[16px] font-semibold leading-none text-zinc-950"><%= titulo || appName %></h1>

            <% if (subtitulo) { %>
                <p class="mt-2 text-sm text-zinc-500"><%= subtitulo %></p>
            <% } %>
        </div>

        <div class="hidden items-center gap-3 md:flex">
            <% if (currentUser) { %>
                <div class="text-right">
                    <p class="text-xs font-medium text-zinc-500"><%= currentUser.rol %></p>
                    <p class="text-sm font-medium text-zinc-950"><%= currentUser.nombre %></p>
                </div>

                <form action="/login/logout" method="POST">
                    <button type="submit" class="btn-secondary px-3 py-2 text-xs">Salir</button>
                </form>
            <% } else { %>
                <span class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs font-medium text-zinc-600">
                    Panel administrativo
                </span>
            <% } %>
        </div>
    </div>
</header>