<%- include("partials/head", { titulo }) %>
<%- include("partials/auth-start") %>

<div class="auth-card text-center">
    <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-zinc-500"><%= statusCode %></p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-zinc-950"><%= message %></h1>
    <p class="mt-3 text-sm leading-6 text-zinc-500">Vuelve al panel principal para continuar.</p>

    <div class="mt-8 grid gap-3 sm:grid-cols-2">
        <a href="/dashboard" class="btn-primary">Ir al dashboard</a>
        <a href="/socios" class="btn-secondary">Ver socios</a>
    </div>
</div>

<%- include("partials/auth-end") %>