<%- include("../partials/head", { titulo: "Acceso" }) %>
<%- include("../partials/auth-start") %>

<div class="auth-card">
	<div>
		<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-zinc-500">Acceso al sistema</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-950">Gestor de Asociaciones</h1>
		<p class="mt-3 text-sm leading-6 text-zinc-500">
			Inicia sesión para gestionar socios y revisar la actividad del sistema.
		</p>
	</div>

	<% if (formError) { %>
		<div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm leading-6 text-rose-700">
			<%= formError %>
		</div>
	<% } %>

	<form action="/login" method="POST" class="mt-8 space-y-5">
		<div class="space-y-2">
			<label for="email" class="label">Email</label>
			<input
				type="email"
				id="email"
				name="email"
				class="<%= errores.email ? 'input input-invalid' : 'input' %>"
				value="<%= valores.email || '' %>"
				autocomplete="email"
				required>
			<% if (errores.email) { %>
				<p class="form-error"><%= errores.email %></p>
			<% } %>
		</div>

		<div class="space-y-2">
			<label for="password" class="label">Contraseña</label>
			<input
				type="password"
				id="password"
				name="password"
				class="<%= errores.password ? 'input input-invalid' : 'input' %>"
				autocomplete="current-password"
				required>
			<% if (errores.password) { %>
				<p class="form-error"><%= errores.password %></p>
			<% } %>
		</div>

		<button type="submit" class="btn-primary w-full">Iniciar sesión</button>
	</form>

	<% if (modoDesarrollo) { %>
		<div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900">
			<p class="font-medium">Acceso de demostración</p>
			<p class="mt-1 text-amber-800">
				Pulsa el botón para entrar directamente con el usuario <strong><%= demoEmail %></strong>.
				Está habilitado solo en desarrollo.
			</p>
			<form action="/login/demo" method="POST" class="mt-4">
				<button type="submit" class="btn-secondary w-full">Entrar como demo</button>
			</form>
		</div>
	<% } %>
</div>

<%- include("../partials/auth-end") %>
