<%- include("../partials/head") %>

<body>

    <h1>Socios</h1>

    <table border="1" cellpadding="8">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Apellidos</th>
                <th>DNI</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th>Estado</th>
            </tr>
        </thead>

        <tbody>
            <% socios.forEach(socio => { %>

                <tr>
                    <td><%= socio.nombre %></td>
                    <td><%= socio.apellidos %></td>
                    <td><%= socio.dni %></td>
                    <td><%= socio.email %></td>
                    <td><%= socio.telefono %></td>
                    <td><%= socio.activo ? "Activo" : "Inactivo" %></td>
                </tr>

            <% }) %>
        </tbody>
    </table>

</body>

<%- include("../partials/footer") %>