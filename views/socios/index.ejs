<%- include("../partials/head") %>

<body>

    <%- include("../partials/header") %>

    <div class="layout">

        <%- include("../partials/sidebar") %>

        <main class="main">

            <div class="page-header">

                <h1>Socios</h1>

                <a href="/socios/nuevo" class="btn btn-primary">
                    Nuevo socio
                </a>

            </div>

            <%- include("../partials/flash") %>

            <div class="card">

                <table class="table">

                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Apellidos</th>
                            <th>DNI</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% socios.forEach(socio => { %>

                            <tr>

                                <td><%= socio.nombre %></td>
                                <td><%= socio.apellidos %></td>
                                <td><%= socio.dni %></td>
                                <td><%= socio.email %></td>
                                <td><%= socio.telefono %></td>
<td>
    <% if (socio.activo) { %>
        <span class="badge badge-success">Activo</span>
    <% } else { %>
        <span class="badge badge-danger">Inactivo</span>
    <% } %>
</td>
                                <td>

                                    <div class="table-actions">

                                        <a
                                            href="/socios/<%= socio.id %>/editar"
                                            class="btn btn-warning btn-sm">
                                            Editar
                                        </a>

                                        <% if (socio.activo) { %>

                                            <form
                                                action="/socios/<%= socio.id %>/eliminar"
                                                method="POST">

                                                <button
                                                    type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="return confirm('¿Dar de baja este socio?')">

                                                    Dar de baja

                                                </button>

                                            </form>

                                        <% } %>

                                    </div>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </main>

    </div>

</body>

</html>